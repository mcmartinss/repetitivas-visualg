Algoritmo "teste enquanto"

Var

 x, soma : inteiro

Inicio

   soma <- 0
   escreva("Digite o primeiro numero: ")
   leia(x)
   
   
   enquanto x <> 0 faca
     soma <- soma + x
      escreva("Digite outro numero: ")
      leia(x)
   fimenquanto

   escreval("Soma = ", soma:4:2)
   
Fimalgoritmo