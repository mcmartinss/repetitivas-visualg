Algoritmo "exercicio senha"

Var

 senha : real
  
Inicio

  escreva("Digite a senha: ")
  leia(senha)
  
  enquanto senha <> 2002 faca
     escreval("Senha incorreta! Tente novamente: ")
      leia(senha)

  se senha = 2002 entao
    escreval("Acesso permitido!")
  fimse
  
  fimenquanto

  

Fimalgoritmo